{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "command -v python3 >/dev/null 2>&1 && python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/session-check.py\" || exit 0",
            "timeout": 5,
            "statusMessage": "Checking Obsidian memory link..."
          }
        ]
      }
    ]
  }
}
